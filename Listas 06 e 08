resultados = [] # Lista vazia para armazenar os textos

for i in range(5):
    nome = input(f"Nome do Aluno {i+1}: ")
    nota = float(input(f"Nota do Aluno {i+1}: "))
    
    # Lógica de decisão (if/elif/else)
    if nota >= 7:
        status = "Aprovado"
    elif nota >= 5:
        status = "Recuperação"
    else:
        status = "Reprovado"
    
    # Adicionando a string formatada à lista
    resultados.append(f"{nome} - {status}")

print("\n--- Relatório Final ---")
print(resultados)


